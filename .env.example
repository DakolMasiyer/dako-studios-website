# ─────────────────────────────────────────────────────────────────────────────
# Dako Studios — environment variables
# Copy to .env.local and fill in. The outreach pipeline degrades gracefully:
# missing Supabase -> CRM falls back to content/leads.json; missing Resend/Gmail/
# Firecrawl -> those routes safely no-op.
# ─────────────────────────────────────────────────────────────────────────────

# --- Marketing dashboard auth (existing) -------------------------------------
MARKETING_DASHBOARD_PASSWORD=
MARKETING_SESSION_SECRET=

# --- Contact form intake (existing) ------------------------------------------
# AIRTABLE_PERSONAL_ACCESS_TOKEN=
# AIRTABLE_BASE_ID=
# AIRTABLE_TABLE_NAME=SME / Film Pipeline
# NOTIFICATION_EMAIL=hello@dako.studio
# Form notification sender — MUST be on the domain verified in Resend.
# Defaults to intake@mail.dako.studio (the currently-verified domain).
# INTAKE_FROM=Dako Studios Intake <intake@mail.dako.studio>

# --- Supabase (lead store) ---------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Outreach SENDING: Resend (DMARC-aligned) --------------------------------
# Cold outreach sends via Resend so DKIM signs as our domain and DMARC passes
# (Gmail send-as fails DMARC alignment). Same RESEND_API_KEY also used by intake.
# Verify the mail.dako.studio subdomain in Resend before going live.
RESEND_API_KEY=
OUTREACH_FROM=Dakol <outreach@mail.dako.studio>
OUTREACH_REPLY_TO=outreach@mail.dako.studio
OUTREACH_FROM_NAME=Dakol
# Optional: domain used to mint our Message-ID (defaults to the OUTREACH_FROM domain)
# OUTREACH_MSGID_DOMAIN=mail.dako.studio

# --- Outreach REPLY DETECTION: Gmail (READ ONLY) -----------------------------
# OAuth2 client + refresh token for the inbox that receives Cloudflare-routed
# replies to outreach@mail.dako.studio. Needs only gmail.readonly scope.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# SAFETY GATE: must be exactly "false" to actually send. Anything else = dry-run
# (logs would-be emails, reads no replies, writes nothing). Keep on until go-live.
OUTREACH_DRY_RUN=true

# --- Gemini (reply triage) ---------------------------------------------------
GEMINI_API_KEY=
# Optional override; defaults to gemini-2.5-flash. Use gemini-2.5-pro for more nuance.
# GEMINI_MODEL=gemini-2.5-flash

# --- Firecrawl (Loop A prospecting) ------------------------------------------
FIRECRAWL_API_KEY=
# FIRECRAWL_BASE_URL=https://api.firecrawl.dev

# --- Cron protection ---------------------------------------------------------
# Vercel Cron sends "Authorization: Bearer <CRON_SECRET>". Set a long random value.
CRON_SECRET=
